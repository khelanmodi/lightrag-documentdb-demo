# =============================================================================
# Backend environment configuration
# Copy this file to backend/.env and fill in the secrets.
#
# Two LLM/embedding providers are supported. Pick ONE:
#   1) Azure OpenAI  -- preferred for Microsoft data (MSProtect sanctioned).
#   2) OpenAI.com    -- fine for external/demo data only.
# If both are configured, Azure wins.
# =============================================================================

# ---- (1) Azure OpenAI -----------------------------------------------------
# Provision with:
#   az group create -n german-<date>-rg -l eastus2
#   az cognitiveservices account create --kind OpenAI --sku S0 ... --custom-domain ...
#   az cognitiveservices account deployment create --deployment-name gpt-4o-mini ...
#   az cognitiveservices account deployment create --deployment-name text-embedding-3-small ...
# Then read endpoint + key:
#   az cognitiveservices account show -g <rg> -n <aoai> --query properties.endpoint -o tsv
#   az cognitiveservices account keys list -g <rg> -n <aoai> --query key1 -o tsv
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# ---- (2) OpenAI.com fallback ----------------------------------------------
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ---- Azure DocumentDB connection ------------------------------------------
# Full mongodb:// URI for the Azure DocumentDB cluster.
# - For managed Azure DocumentDB: copy the SRV connection string from the portal.
# - For OSS DocumentDB: requires image 0.110.0+ (PR #459 _id lookup fix).
# - replicaSet=rs0 is stripped automatically by config._clean_uri when present.
DOCUMENTDB_URI=mongodb://user:pass@your-cluster.global.mongocluster.cosmos.azure.com:10260/?tls=true&authMechanism=SCRAM-SHA-256&retrywrites=false&maxIdleTimeMS=120000

# ---- Database / collections -----------------------------------------------
# Single database name shared by all three retrieval strategies:
#   vector_docs          (Naive RAG  -- DocumentDB native vector index)
#   lightrag_kv          (LightRAG: KV cache)
#   lightrag_graph       (LightRAG: graph nodes + edges)
#   lightrag_doc_status  (LightRAG: ingest state)
DB_NAME=lightrag_demo

# ---- Models / deployment names --------------------------------------------
# When AZURE_OPENAI_ENDPOINT is set, LLM_MODEL and EMBED_MODEL are interpreted
# as Azure **deployment names**. Easiest convention: name the deployment after
# the model id so this template works for both providers.
LLM_MODEL=gpt-4o-mini

# Embedding model + dimensionality (must match the DocumentDB vector index).
# Change BOTH together; the index is rebuilt on first boot to match EMBED_DIM.
EMBED_MODEL=text-embedding-3-small
EMBED_DIM=1536

# ---- Timeouts -------------------------------------------------------------
# Seconds. LightRAG-Hybrid chains multiple LLM calls per query; 120s is safe.
LLM_TIMEOUT=120

# ---- LightRAG local storage ----------------------------------------------
# Path inside the backend container for LightRAG's NanoVectorDB cache.
# In Docker this is mounted as a named volume (see docker-compose.yml).
LIGHTRAG_WORKING_DIR=./lightrag_storage

