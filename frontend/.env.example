# =============================================================================
# Frontend environment configuration
# Copy this file to frontend/.env (or .env.local) and adjust as needed.
# Only variables prefixed with VITE_ are exposed to the browser bundle.
# =============================================================================

# ---- Backend URL ----------------------------------------------------------
# Base URL the React app talks to.
#
# - Local dev (vite proxy):        leave unset -- requests go to /api and are
#                                  proxied to http://localhost:8000 by
#                                  vite.config.js.
# - Docker Compose:                set by docker-compose.yml to
#                                  http://localhost:8000 (no need to edit here).
# - GitHub Pages / Container Apps: set to the public backend URL at build time,
#                                  e.g. https://lightrag-demo-backend.<id>.<region>.azurecontainerapps.io
VITE_BACKEND_URL=http://localhost:8000
